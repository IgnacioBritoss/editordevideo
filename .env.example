# ──────────────────────────────────────────────────────────────────────────────
# IMÁGENES — configurá al menos uno
# ──────────────────────────────────────────────────────────────────────────────

# Google Custom Search (100 búsquedas/día gratis — las mejores imágenes)
# 1. Activá Custom Search API en https://console.cloud.google.com
# 2. Creá un motor de búsqueda en https://programmablesearchengine.google.com
#    → En "Búsqueda en toda la web" marcá "Sí"
# 3. Copiá la API Key y el Search Engine ID (cx)
GOOGLE_API_KEY=
GOOGLE_CX=

# Pexels (200 req/hora gratis — fallback automático cuando Google se agota)
# Registrate en https://www.pexels.com/api/  y copiá tu API key
PEXELS_API_KEY=ds7Un74os2up9JSOvDAkkFUX4QxcedVWHE04ig7zHtVWkGBHP5W5Jrr7

# ──────────────────────────────────────────────────────────────────────────────
# TRANSCRIPCIÓN — opcional (si no ponés nada, usa Whisper local gratis)
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI Whisper API (más rápido, cuesta ~$0.006/min)
# Si no lo configurás, usa faster-whisper en tu máquina (gratis pero tarda más)
OPENAI_API_KEY=
